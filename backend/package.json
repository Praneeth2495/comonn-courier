    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "express-validator": "^7.2.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "node-cron": "^4.6.0",
    "pdfkit": "^0.15.0",
    "razorpay": "^2.9.4",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.4",
    "prisma": "^5.18.0"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "allowScripts": {
    "prisma@5.22.0": true,
