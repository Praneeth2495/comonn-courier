// ============================================================
// Comonn International Courier — Database Schema
// ============================================================
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Atomic per-month sequence counters for human-friendly order/tracking
// numbers (DDMM0<seq>, seq resets each calendar month). Keyed by
// "<kind>-<year>-<month>" e.g. "order-2026-07". A plain count()-then-+1
// races under concurrent order creation; this table's row is updated
// with a single atomic UPDATE per request instead.
model SequenceCounter {
  key   String @id
  value Int    @default(0)
}

// ------------------------------------------------------------
// Auth / Users
// ------------------------------------------------------------
enum Role {
  CUSTOMER
  ADMIN
  STAFF
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  fullName     String
  phone        String?
  company      String?
  role         Role     @default(CUSTOMER)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  addresses Address[]
  orders    Order[]
  auditLogs AuditLog[]

  @@index([email])
}

model Address {
  id         String   @id @default(uuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  label      String? // "Home", "Warehouse", etc.
  contactName String
  phone      String
  email      String?
  instructions String? // pickup instructions (sender) or delivery instructions (receiver)
  line1      String
  line2      String?
  city       String
  state      String?
  postcode   String
  countryCode String  // ISO 3166-1 alpha-2, e.g. "AU"
  isDefault  Boolean  @default(false)
  isSaved    Boolean  @default(false) // true = user's address book entry; false = a per-order snapshot
  createdAt  DateTime @default(now())

  ordersAsSender   Order[] @relation("SenderAddress")
  ordersAsReceiver Order[] @relation("ReceiverAddress")
}

// ------------------------------------------------------------
// Pricing: Zones, Countries, Rate Cards
// ------------------------------------------------------------
// A Zone groups destination countries that share the same rate table
// (typical for international courier pricing: Zone A = neighbouring
// region, Zone B = wider region, Zone C = rest of world, etc).
model Zone {
  id          String   @id @default(uuid())
  code        String   @unique // "ZONE_A"
  name        String            // "Zone A — Asia Pacific"
  countries   CountryZone[]
  rateCards   RateCard[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CountryZone {
  id          String @id @default(uuid())
  countryCode String @unique // ISO alpha-2
  countryName String
  zoneId      String
  zone        Zone   @relation(fields: [zoneId], references: [id])
}

// A Service is a product line: Express, Economy, Freight, Documents...
model Service {
  id            String   @id @default(uuid())
  code          String   @unique // "EXPRESS"
  name          String            // "Express Worldwide"
  description   String?
  transitDaysMin Int
  transitDaysMax Int
  volumetricDivisor Int  @default(5000) // cm3 per kg, industry-standard default
  isActive      Boolean  @default(true)
  rateCards     RateCard[]
  orders        Order[]
}

// RateCard = one weight-break price for a given service + zone.
// e.g. Service=EXPRESS, Zone=ZONE_A, 0-0.5kg => $18.50 base,
// then perKgAbove for weight beyond the bracket ceiling.
model RateCard {
  id             String   @id @default(uuid())
  serviceId      String
  service        Service  @relation(fields: [serviceId], references: [id])
  zoneId         String
  zone           Zone     @relation(fields: [zoneId], references: [id])
  weightFromKg   Decimal  @db.Decimal(10, 3) // inclusive lower bound
  weightToKg     Decimal  @db.Decimal(10, 3) // inclusive upper bound
  basePrice      Decimal  @db.Decimal(10, 2) // INR
  perKgOverage   Decimal  @db.Decimal(10, 2) // price per kg once weight exceeds weightToKg of the last bracket
  currency       String   @default("INR")
  effectiveFrom  DateTime @default(now())
  effectiveTo    DateTime?
  isActive       Boolean  @default(true)

  @@index([serviceId, zoneId, weightFromKg, weightToKg])
}

// Optional extra fees layered on top of the base rate card lookup
model Surcharge {
  id          String   @id @default(uuid())
  code        String   @unique // "FUEL", "REMOTE_AREA", "OVERSIZE"
  name        String
  type        String   // "PERCENT" | "FLAT"
  value       Decimal  @db.Decimal(10, 4)
  appliesToServiceId String?
  isActive    Boolean  @default(true)
}

// ------------------------------------------------------------
// Orders / Shipments
// ------------------------------------------------------------
enum OrderStatus {
  DRAFT           // quote created, not yet booked
  PENDING_PAYMENT
  PAID
  LABEL_GENERATED
  PICKED_UP
  IN_TRANSIT
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
  EXCEPTION
}

model Order {
  id             String      @id @default(uuid())
  orderNumber    String      @unique // human-friendly e.g. CMN-2026-000123
  userId         String?
  user           User?       @relation(fields: [userId], references: [id])

  serviceId      String
  service        Service     @relation(fields: [serviceId], references: [id])

  senderAddressId   String
  senderAddress     Address  @relation("SenderAddress", fields: [senderAddressId], references: [id])
  receiverAddressId String
  receiverAddress   Address  @relation("ReceiverAddress", fields: [receiverAddressId], references: [id])

  // parcel physical details — totals across all OrderItem lines (a shipment
  // can have multiple items; per-item dims/weight live on OrderItem)
  actualWeightKg    Decimal  @db.Decimal(10, 3)
  volumetricWeightKg Decimal @db.Decimal(10, 3)
  chargeableWeightKg Decimal @db.Decimal(10, 3) // sum of each item's max(actual, volumetric) * quantity
  declaredValue      Decimal @db.Decimal(10, 2) @default(0)
  contentsDescription String?
  items               OrderItem[]

  // pricing snapshot (never recompute historical orders off live rate cards)
  zoneCode        String
  baseFreight     Decimal @db.Decimal(10, 2)
  surchargesTotal Decimal @db.Decimal(10, 2) @default(0)
  addonsTotal     Decimal @db.Decimal(10, 2) @default(0)
  discountTotal   Decimal @db.Decimal(10, 2) @default(0)
  taxRate         Decimal @db.Decimal(6, 4) @default(0)
  taxTotal        Decimal @db.Decimal(10, 2) @default(0)
  grandTotal      Decimal @db.Decimal(10, 2)
  currency        String  @default("INR")
  pricingBreakdown Json?  // full itemised breakdown for transparency/audit

  addons          OrderAddon[]
  promoCode       String?

  // "Not sure, book pickup": weight/dimensions unknown at booking time, so
  // no price is computed — courier assesses and collects cash at pickup.
  pricingPending  Boolean   @default(false)

  // pre-payment gates (Payment page)
  dgAcknowledged  Boolean   @default(false) // dangerous-goods declaration
  pickupDate      String?
  otpEmail        String?
  otpCode         String?   // never returned to the client
  otpExpiresAt    DateTime?
  otpVerifiedAt   DateTime?

  status          OrderStatus @default(DRAFT)
  trackingNumber  String?     @unique

  payment         Payment?
  labels          Label[]
  invoice         Invoice?
  trackingEvents  TrackingEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([userId])
}

// One physical package within a (possibly multi-item) shipment.
model OrderItem {
  id                 String  @id @default(uuid())
  orderId            String
  order              Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  itemType           String  // "Box" | "Pallet"
  actualWeightKg     Decimal @db.Decimal(10, 3) // per single unit
  lengthCm           Decimal @db.Decimal(10, 2)
  widthCm            Decimal @db.Decimal(10, 2)
  heightCm           Decimal @db.Decimal(10, 2)
  quantity           Int     @default(1)
  volumetricWeightKg Decimal @db.Decimal(10, 3) // per single unit
  chargeableWeightKg Decimal @db.Decimal(10, 3) // max(actual, volumetric) * quantity, this line's total
  createdAt          DateTime @default(now())

  @@index([orderId])
}

// Extra-protection add-on selected on the Payment page (transit warranty
// tier, heavy-duty cardboard, packing/wrapping service).
model OrderAddon {
  id        String  @id @default(uuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  code      String  // "WARRANTY" | "CARDBOARD" | "PACKING" | "WRAPPING"
  label     String
  quantity  Int     @default(1)
  unitPrice Decimal @db.Decimal(10, 2)
  amount    Decimal @db.Decimal(10, 2) // unitPrice * quantity
  createdAt DateTime @default(now())

  @@index([orderId])
}

model PromoCode {
  id             String    @id @default(uuid())
  code           String    @unique
  type           String    // "PERCENT" | "FLAT"
  value          Decimal   @db.Decimal(10, 4)
  isActive       Boolean   @default(true)
  expiresAt      DateTime?
  maxRedemptions Int?
  timesRedeemed  Int       @default(0)
  createdAt      DateTime  @default(now())
}

// ------------------------------------------------------------
// Payments (Razorpay Orders — provider-agnostic schema)
// ------------------------------------------------------------
enum PaymentStatus {
  REQUIRES_PAYMENT
  PROCESSING
  SUCCEEDED
  FAILED
  REFUNDED
  CASH_PENDING // cash booking confirmed, amount to be collected at pickup
}

model Payment {
  id                    String   @id @default(uuid())
  orderId               String   @unique
  order                 Order    @relation(fields: [orderId], references: [id])
  provider              String   @default("razorpay")
  providerOrderId       String?  // Razorpay Order id (order_xxx)
  providerPaymentId     String?  // Razorpay Payment id (pay_xxx), set once captured
  amount                Decimal  @db.Decimal(10, 2)
  currency              String   @default("INR")
  status                PaymentStatus @default(REQUIRES_PAYMENT)
  method                String?  // "card" | "paypal" | ...
  rawWebhookPayload     Json?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

// ------------------------------------------------------------
// Labels
// ------------------------------------------------------------
// One physical package's shipping label. A multi-item order (e.g. 3 boxes)
// gets one Label per package, each independently barcoded but linked back
// to the same order/tracking number.
model Label {
  id           String   @id @default(uuid())
  orderId      String
  order        Order    @relation(fields: [orderId], references: [id])
  packageIndex Int
  itemType     String
  fileUrl      String   // path/URL to generated PDF
  barcodeValue String   @unique
  generatedAt  DateTime @default(now())

  @@index([orderId])
}

model Invoice {
  id          String   @id @default(uuid())
  orderId     String   @unique
  order       Order    @relation(fields: [orderId], references: [id])
  fileUrl     String
  generatedAt DateTime @default(now())
}

// ------------------------------------------------------------
// Tracking
// ------------------------------------------------------------
model TrackingEvent {
  id        String      @id @default(uuid())
  orderId   String
  order     Order       @relation(fields: [orderId], references: [id])
  status    OrderStatus
  location  String?
  note      String?
  occurredAt DateTime   @default(now())
}

// ------------------------------------------------------------
// Audit log (admin actions)
// ------------------------------------------------------------
model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String
  entity    String
  entityId  String?
  meta      Json?
  createdAt DateTime @default(now())
}
