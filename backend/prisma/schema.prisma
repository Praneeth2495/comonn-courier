// ============================================================
// Comonn International Courier — Database Schema
// ============================================================
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Atomic per-month sequence counters for human-friendly order/tracking
// numbers (DDMM0<seq>, seq resets each calendar month). Keyed by
// "<kind>-<year>-<month>" e.g. "order-2026-07". A plain count()-then-+1
// races under concurrent order creation; this table's row is updated
// with a single atomic UPDATE per request instead.
model SequenceCounter {
  key   String @id
  value Int    @default(0)
}

// ------------------------------------------------------------
// Auth / Users
// ------------------------------------------------------------
enum Role {
  CUSTOMER
  ADMIN
  STAFF
  DRIVER
}

model User {
  id                      String    @id @default(uuid())
  email                   String    @unique
  passwordHash            String
  fullName                String
  phone                   String?
  company                 String?
  role                    Role      @default(CUSTOMER)
  isActive                Boolean   @default(true)
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
  // Null for a guest-checkout account auto-created with an unusable random
  // password (see accountProvisioning.js) until the customer actually
  // chooses one; set immediately for self-registered accounts. Drives the
  // 1-hour account-setup follow-up email (see accountSetupFollowup.js).
  passwordSetAt           DateTime?
  accountSetupEmailSentAt DateTime?

  addresses         Address[]
  orders            Order[]
  auditLogs         AuditLog[]
  zoneAssignments   StaffZoneAssignment[]
  passwordSetTokens PasswordSetToken[]
  orderComments     OrderComment[]
  driverJobs        Order[]               @relation("OrderDriver")
  inventoryUpdates  InventoryItem[]
  scanBatches       ScanBatch[]
  scanLocations     ScanLocation[]

  @@index([email])
}

// Internal admin/staff notes on an order. Deliberately separate from
// TrackingEvent, whose `note` field is exposed on the public,
// unauthenticated /api/track endpoint — an internal comment must never
// leak there.
model OrderComment {
  id        String   @id @default(uuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  body      String
  createdAt DateTime @default(now())

  @@index([orderId])
}

// Issued when an account is auto-created for a guest checkout (or when a
// customer requests "Forgot password"). The raw token is emailed to the
// customer and only its hash is stored, same pattern as the OTP flow.
model PasswordSetToken {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

model Address {
  id           String   @id @default(uuid())
  userId       String?
  user         User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  label        String? // "Home", "Warehouse", etc.
  contactName  String
  phone        String
  email        String?
  instructions String? // pickup instructions (sender) or delivery instructions (receiver)
  line1        String
  line2        String?
  city         String
  state        String?
  postcode     String
  countryCode  String // ISO 3166-1 alpha-2, e.g. "AU"
  isDefault    Boolean  @default(false)
  isSaved      Boolean  @default(false) // true = user's address book entry; false = a per-order snapshot
  createdAt    DateTime @default(now())

  ordersAsSender   Order[] @relation("SenderAddress")
  ordersAsReceiver Order[] @relation("ReceiverAddress")
}

// ------------------------------------------------------------
// Pricing: Zones, Countries, Rate Cards
// ------------------------------------------------------------
// A Zone groups destination countries that share the same rate table
// (typical for international courier pricing: Zone A = neighbouring
// region, Zone B = wider region, Zone C = rest of world, etc).
model Zone {
  id               String                @id @default(uuid())
  code             String                @unique // "ZONE_A"
  name             String // "Zone A — Asia Pacific"
  // "destination" = customer-facing shipping zone, matched via CountryZone
  // and used as RateCard.zoneId. "origin" = domestic India pickup-postcode
  // classification (e.g. "India-urban"), matched via PostcodeZone and used
  // as RateCard.fromZoneId — kept distinct so the admin's destination-zone
  // dropdown never gets polluted with origin-only zones.
  kind             String                @default("destination")
  countries        CountryZone[]
  postcodeZones    PostcodeZone[]
  rateCards        RateCard[]            @relation("RateCardZone")
  rateCardsFrom    RateCard[]            @relation("RateCardFromZone")
  staffAssignments StaffZoneAssignment[]
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
}

// Maps a domestic India pickup postcode to an origin Zone (kind="origin"),
// so pricing can optionally differ by pickup location via
// RateCard.fromZoneId — imported from the same source as
// PostcodeSuggestion. A postcode not found here has no origin-zone
// restriction (matches any RateCard, i.e. treated as the baseline/default).
model PostcodeZone {
  id          String  @id @default(uuid())
  countryCode String // ISO alpha-2, e.g. "IN"
  postcode    String
  zoneId      String
  zone        Zone    @relation(fields: [zoneId], references: [id])
  // Optional human-facing sub-area name for this postcode (e.g.
  // "Hyderabad", "Vijayawada") — independent of `zone` (which drives
  // pricing). Powers the admin Pickup-orders panel's origin
  // state/region filters; null for postcodes with no region assigned.
  region      String?

  @@unique([countryCode, postcode])
  @@index([countryCode, region])
}

// Admin-controlled: which STAFF accounts can see/filter Pickup & Delivery
// orders in which zones. A staff member with no rows here sees no orders
// (opt-in, so admin explicitly divides zones among staff rather than
// everyone seeing everything by default).
model StaffZoneAssignment {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  zoneId    String
  zone      Zone     @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, zoneId])
}

model CountryZone {
  id          String @id @default(uuid())
  countryCode String @unique // ISO alpha-2
  countryName String
  zoneId      String
  zone        Zone   @relation(fields: [zoneId], references: [id])
}

// Postcode -> suburb/state autocomplete for the sender/receiver address
// forms (India only for now — imported from an Australia-Post-style
// suggestion list). One postcode maps to many suburbs, so lookups return a
// list for the customer to pick from rather than a single match.
model PostcodeSuggestion {
  id          String @id @default(uuid())
  countryCode String // ISO alpha-2, e.g. "IN"
  postcode    String
  suburb      String
  state       String

  @@index([countryCode, postcode])
}

// A Service is a product line: Express, Economy, Freight, Documents...
model Service {
  id                String     @id @default(uuid())
  code              String     @unique // "EXPRESS"
  name              String // "Express Worldwide"
  description       String?
  transitDaysMin    Int
  transitDaysMax    Int
  volumetricDivisor Int        @default(5000) // cm3 per kg, industry-standard default
  isActive          Boolean    @default(true)
  rateCards         RateCard[]
  orders            Order[]
}

// RateCard = one weight-break price for a given service + destination zone,
// optionally narrowed further by an origin (pickup) zone.
// e.g. Service=EXPRESS, Zone=ZONE_A, 0-0.5kg => $18.50 base,
// then perKgAbove for weight beyond the bracket ceiling.
model RateCard {
  id             String    @id @default(uuid())
  serviceId      String
  service        Service   @relation(fields: [serviceId], references: [id])
  zoneId         String
  zone           Zone      @relation("RateCardZone", fields: [zoneId], references: [id])
  // Optional origin (pickup) zone — e.g. a bracket that only applies when
  // picking up from an "India-rural" postcode. NULL matches any origin, so
  // every existing rate card (with no origin dimension) keeps working
  // unchanged; a bracket with a specific fromZoneId is preferred over a
  // NULL one when both match (see pricingEngine.js's findRateBracket).
  fromZoneId     String?
  fromZone       Zone?     @relation("RateCardFromZone", fields: [fromZoneId], references: [id])
  weightFromKg   Decimal   @db.Decimal(10, 3) // inclusive lower bound
  weightToKg     Decimal   @db.Decimal(10, 3) // inclusive upper bound
  basePrice      Decimal   @db.Decimal(10, 2) // INR
  perKgOverage   Decimal   @db.Decimal(10, 2) // price per kg once weight exceeds weightToKg of the last bracket
  currency       String    @default("INR")
  // Optional per-bracket delivery timeframe override — falls back to the
  // Service's own transitDaysMin/Max (see pricingEngine.js) when unset, so
  // existing rate cards keep working unchanged.
  transitDaysMin Int?
  transitDaysMax Int?
  effectiveFrom  DateTime  @default(now())
  effectiveTo    DateTime?
  isActive       Boolean   @default(true)

  @@index([serviceId, zoneId, weightFromKg, weightToKg])
  @@index([fromZoneId])
}

// Optional extra fees layered on top of the base rate card lookup
model Surcharge {
  id                 String  @id @default(uuid())
  code               String  @unique // "FUEL", "REMOTE_AREA", "OVERSIZE"
  name               String
  type               String // "PERCENT" | "FLAT"
  value              Decimal @db.Decimal(10, 4)
  appliesToServiceId String?
  isActive           Boolean @default(true)
}

// ------------------------------------------------------------
// Orders / Shipments
// ------------------------------------------------------------
// Not a database enum — status is free text so a barcode location's label
// can become a genuine new order status (e.g. "Sorted at hub"), not just
// one of the fixed lifecycle values below. Those fixed values remain the
// ones the rest of the app's business logic (payment flow, driver actions,
// admin tab groupings, cancellation rules) checks for by exact string:
// DRAFT, PENDING_PAYMENT, PICKUP_CONFIRMED, PAID, LABEL_GENERATED,
// PICKED_UP, IN_TRANSIT, OUT_FOR_DELIVERY, DELIVERED, CANCELLED, EXCEPTION.

model Order {
  id          String  @id @default(uuid())
  orderNumber String  @unique // human-friendly e.g. CMN-2026-000123
  userId      String?
  user        User?   @relation(fields: [userId], references: [id])

  serviceId String
  service   Service @relation(fields: [serviceId], references: [id])

  senderAddressId   String
  senderAddress     Address @relation("SenderAddress", fields: [senderAddressId], references: [id])
  receiverAddressId String
  receiverAddress   Address @relation("ReceiverAddress", fields: [receiverAddressId], references: [id])

  // parcel physical details — totals across all OrderItem lines (a shipment
  // can have multiple items; per-item dims/weight live on OrderItem)
  actualWeightKg      Decimal     @db.Decimal(10, 3)
  volumetricWeightKg  Decimal     @db.Decimal(10, 3)
  chargeableWeightKg  Decimal     @db.Decimal(10, 3) // sum of each item's max(actual, volumetric) * quantity
  declaredValue       Decimal     @default(0) @db.Decimal(10, 2)
  contentsDescription String?
  items               OrderItem[]

  // pricing snapshot (never recompute historical orders off live rate cards)
  zoneCode         String
  baseFreight      Decimal @db.Decimal(10, 2)
  surchargesTotal  Decimal @default(0) @db.Decimal(10, 2)
  addonsTotal      Decimal @default(0) @db.Decimal(10, 2)
  discountTotal    Decimal @default(0) @db.Decimal(10, 2)
  taxRate          Decimal @default(0) @db.Decimal(6, 4)
  taxTotal         Decimal @default(0) @db.Decimal(10, 2)
  grandTotal       Decimal @db.Decimal(10, 2)
  currency         String  @default("INR")
  pricingBreakdown Json? // full itemised breakdown for transparency/audit

  addons    OrderAddon[]
  promoCode String?

  // "Not sure, book pickup": weight/dimensions unknown at booking time, so
  // no price is computed — courier assesses and collects cash at pickup.
  // No label/invoice is generated for these; a booking-confirmation email
  // goes to the sender instead (confirmationEmailSentAt guards against
  // re-sending it on page reload, since these orders never get a Label row).
  pricingPending          Boolean   @default(false)
  confirmationEmailSentAt DateTime?

  // pre-payment gates (Payment page)
  dgAcknowledged Boolean   @default(false) // dangerous-goods declaration
  pickupDate     String?
  otpEmail       String?
  otpCode        String? // never returned to the client
  otpExpiresAt   DateTime?
  otpVerifiedAt  DateTime?

  status         String  @default("DRAFT")
  trackingNumber String? @unique
  invoiceNumber  String? @unique // "IN1", "IN2"... assigned at booking time, resets only on calendar year change

  // Physical pickup dispatch: staff/admin send a pickup job directly to a
  // driver account, who then sees it in their own portal and marks it
  // PICKED_UP once collected in person.
  assignedDriverId String?
  assignedDriver   User?     @relation("OrderDriver", fields: [assignedDriverId], references: [id])
  driverAssignedAt DateTime?
  driverArrivedAt  DateTime? // driver marked "Arrived for pickup"
  pickedUpAt       DateTime? // driver marked "Pickup completed" (distinct from updatedAt, which later status changes would otherwise shift)

  payment        Payment?
  labels         Label[]
  invoice        Invoice?
  trackingEvents TrackingEvent[]
  comments       OrderComment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([userId])
  @@index([assignedDriverId])
}

// One physical package within a (possibly multi-item) shipment.
model OrderItem {
  id                 String   @id @default(uuid())
  orderId            String
  order              Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  itemType           String // "Box" | "Pallet"
  actualWeightKg     Decimal  @db.Decimal(10, 3) // per single unit
  lengthCm           Decimal  @db.Decimal(10, 2)
  widthCm            Decimal  @db.Decimal(10, 2)
  heightCm           Decimal  @db.Decimal(10, 2)
  quantity           Int      @default(1)
  volumetricWeightKg Decimal  @db.Decimal(10, 3) // per single unit
  chargeableWeightKg Decimal  @db.Decimal(10, 3) // max(actual, volumetric) * quantity, this line's total
  createdAt          DateTime @default(now())

  @@index([orderId])
}

// Extra-protection add-on selected on the Payment page (transit warranty
// tier, heavy-duty cardboard, packing/wrapping service).
model OrderAddon {
  id        String   @id @default(uuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  code      String // "WARRANTY" | "CARDBOARD" | "PACKING" | "WRAPPING"
  label     String
  quantity  Int      @default(1)
  unitPrice Decimal  @db.Decimal(10, 2)
  amount    Decimal  @db.Decimal(10, 2) // unitPrice * quantity
  createdAt DateTime @default(now())

  @@index([orderId])
}

model PromoCode {
  id             String    @id @default(uuid())
  code           String    @unique
  type           String // "PERCENT" | "FLAT"
  value          Decimal   @db.Decimal(10, 4)
  isActive       Boolean   @default(true)
  expiresAt      DateTime?
  maxRedemptions Int?
  timesRedeemed  Int       @default(0)
  createdAt      DateTime  @default(now())
}

// ------------------------------------------------------------
// Payments (Razorpay Orders — provider-agnostic schema)
// ------------------------------------------------------------
enum PaymentStatus {
  REQUIRES_PAYMENT
  PROCESSING
  SUCCEEDED
  FAILED
  REFUNDED
  CASH_PENDING // cash booking confirmed, amount to be collected at pickup
}

model Payment {
  id                String        @id @default(uuid())
  orderId           String        @unique
  order             Order         @relation(fields: [orderId], references: [id])
  provider          String        @default("razorpay")
  providerOrderId   String? // Razorpay Order id (order_xxx)
  providerPaymentId String? // Razorpay Payment id (pay_xxx), set once captured
  amount            Decimal       @db.Decimal(10, 2)
  currency          String        @default("INR")
  status            PaymentStatus @default(REQUIRES_PAYMENT)
  method            String? // "card" | "paypal" | ...
  rawWebhookPayload Json?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
}

// ------------------------------------------------------------
// Labels
// ------------------------------------------------------------
// One physical package's shipping label. A multi-item order (e.g. 3 boxes)
// gets one Label per package, each independently barcoded but linked back
// to the same order/tracking number.
model Label {
  id           String   @id @default(uuid())
  orderId      String
  order        Order    @relation(fields: [orderId], references: [id])
  packageIndex Int
  itemType     String
  fileUrl      String // path/URL to generated PDF
  barcodeValue String   @unique
  generatedAt  DateTime @default(now())

  @@index([orderId])
}

model Invoice {
  id          String   @id @default(uuid())
  orderId     String   @unique
  order       Order    @relation(fields: [orderId], references: [id])
  fileUrl     String
  generatedAt DateTime @default(now())
}

// ------------------------------------------------------------
// Tracking
// ------------------------------------------------------------
model TrackingEvent {
  id         String   @id @default(uuid())
  orderId    String
  order      Order    @relation(fields: [orderId], references: [id])
  status     String
  location   String?
  note       String?
  occurredAt DateTime @default(now())
}

// ------------------------------------------------------------
// Audit log (admin actions)
// ------------------------------------------------------------
model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String
  entity    String
  entityId  String?
  meta      Json?
  createdAt DateTime @default(now())
}

// ------------------------------------------------------------
// Inventory (equipment/supplies used for courier services)
// ------------------------------------------------------------
model InventoryItem {
  id                String   @id @default(uuid())
  name              String   @unique // "Heavy-duty cardboard", "Wrap rolls"...
  unit              String   @default("pcs") // "boxes" | "rolls" | "pcs" ...
  quantity          Int      @default(0)
  lowStockThreshold Int?
  updatedById       String?
  updatedBy         User?    @relation(fields: [updatedById], references: [id])
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// ------------------------------------------------------------
// Batch scan (staff/admin scan multiple shipping labels at once and
// bulk-update their order status)
// ------------------------------------------------------------
model ScanBatch {
  id          String          @id @default(uuid())
  name        String
  status      String
  createdById String
  createdBy   User            @relation(fields: [createdById], references: [id])
  items       ScanBatchItem[]
  createdAt   DateTime        @default(now())
}

model ScanBatchItem {
  id           String    @id @default(uuid())
  batchId      String
  batch        ScanBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  barcodeValue String
  orderId      String?
  orderNumber  String?
  matched      Boolean   @default(true) // false if the scanned barcode didn't resolve to a label
  createdAt    DateTime  @default(now())

  @@index([batchId])
}

// A physical location (warehouse bay, sorting hub, delivery vehicle...)
// with its own barcode. Scanning it during Batch Scan sets its label as the
// literal new Order.status on every matched order (e.g. "Sorted at hub"),
// and logs the same text as a comment with who scanned it and when.
model ScanLocation {
  id           String   @id @default(uuid())
  name         String // "Warehouse A - Inbound", "Van 3"...
  barcodeValue String   @unique
  label        String // also the literal status applied when scanned
  createdById  String
  createdBy    User     @relation(fields: [createdById], references: [id])
  createdAt    DateTime @default(now())
}
